# ============================================================
# High School Sim - Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to git (it is already in .gitignore).
# ============================================================

# ------------------------------------------------------------------
# 1. SUPABASE — Cloud Save + Authentication
# ------------------------------------------------------------------
# Create a free project at https://supabase.com
# Project Settings > API > URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Project Settings > API > anon / public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ------------------------------------------------------------------
# 2. OPENAI — AI-Powered NPC Dialogue
# ------------------------------------------------------------------
# Get your API key at https://platform.openai.com/api-keys
# Uses GPT-4o-mini (very cheap). Optional — game works without it.
EXPO_PUBLIC_OPENAI_API_KEY=sk-your_openai_key_here

# ------------------------------------------------------------------
# 3. REVENUECAT — In-App Purchases (iOS / Android)
# ------------------------------------------------------------------
# Create an account at https://www.revenuecat.com
# App Settings > API Keys
# Only needed for native iOS/Android builds. Web uses mock fallback.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_revenuecat_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_revenuecat_android_key

# ------------------------------------------------------------------
# Optional: Web Stripe Checkout (if you want real web payments)
# ------------------------------------------------------------------
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
